# Local development environment
# Copy to .env.local and fill in values.
# See infra/config.json for the full infrastructure specification.

# ── Convex ───────────────────────────────────────────────────
# Auto-written by `npx convex dev --once --configure=new`
CONVEX_DEPLOYMENT=dev:your-deployment-name
VITE_CONVEX_URL=https://your-deployment-name.convex.cloud

# ── Sentry (optional for local dev) ─────────────────────────
# VITE_SENTRY_DSN=
# VITE_SENTRY_RELEASE=pub@dev

# Build-time source map upload (not needed locally)
# SENTRY_ORG=
# SENTRY_PROJECT=pub
# SENTRY_AUTH_TOKEN=

# ── PostHog (optional for local dev) ────────────────────────
# VITE_POSTHOG_KEY=

# ── Sandbox (pub-fs Service Worker) ───────────────────────
# Required for sandbox iframe mode (canvas isolation + pub-fs).
# Production: https://sandbox.pub.blue (cross-origin, served by Vercel)
# Dev: /__sandbox__ (same-origin, served by Vite dev middleware)
# Unset: sandbox mode disabled, canvas uses srcDoc fallback (no pub-fs)
VITE_SANDBOX_ORIGIN=/__sandbox__
# PostHog is proxied via /ph (vercel.json rewrites + vite dev proxy)

# ── Convex backend secrets ──────────────────────────────────
# These are NOT set in .env.local — they go in Convex env vars.
# Use `./infra/provision.sh convex --dev` or set manually:
#   npx convex env set AUTH_GITHUB_ID xxx
#   npx convex env set AUTH_GITHUB_SECRET xxx
#   npx convex env set AUTH_GOOGLE_ID xxx
#   npx convex env set AUTH_GOOGLE_SECRET xxx
#   npx convex env set PUB_PUBLIC_URL https://pub.blue
