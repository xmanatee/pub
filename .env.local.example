VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Sentry — crash reporting & performance monitoring
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
VITE_SENTRY_RELEASE=pub@0.1.0

# Sentry source map upload (build-time only, not VITE_ prefixed)
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=pub
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# PostHog — product analytics
VITE_POSTHOG_KEY=phc_your_posthog_project_api_key
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Set these in Convex dashboard environment variables:
# AUTH_GITHUB_ID=your_github_oauth_app_client_id
# AUTH_GITHUB_SECRET=your_github_oauth_app_client_secret
# AUTH_GOOGLE_ID=your_google_oauth_client_id
# AUTH_GOOGLE_SECRET=your_google_oauth_client_secret
# CONVEX_SITE_URL=https://your-deployment.convex.site
