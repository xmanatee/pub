# Pub Infrastructure Secrets
# Copy to .env.secrets and fill in values.
# This file is gitignored — never commit actual secrets.
# Used by: infra/provision.sh

# ── Convex backend env vars ──────────────────────────────────
# OAuth provider credentials (set in Convex dashboard or via provision.sh)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# JWT keys — auto-generated by @convex-dev/auth on first run.
# Only needed when migrating or restoring from backup.
# JWKS=
# JWT_PRIVATE_KEY=

# ── Vercel env vars ──────────────────────────────────────────
VITE_SENTRY_DSN=
SENTRY_ORG=
SENTRY_AUTH_TOKEN=
VITE_POSTHOG_KEY=

# ── CI/CD tokens ─────────────────────────────────────────────
# Convex: Dashboard → Settings → Deploy keys
CONVEX_DEPLOY_KEY=
# Vercel: Settings → Tokens
VERCEL_TOKEN=
# npmjs.com: Access Tokens (for pubblue CLI releases)
NPM_TOKEN=
