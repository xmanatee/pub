{
  "name": "pubblue",
  "version": "0.7.2",
  "description": "CLI for publishing and visualizing AI-agent output via pub.blue",
  "type": "module",
  "bin": {
    "pubblue": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/live-daemon-entry.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/live-daemon-entry.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "build:bin": "bun run build-binary.ts",
    "build:bin:local": "bun build --compile --external @anthropic-ai/claude-agent-sdk --minify src/index.ts --outfile dist-bin/pubblue"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "convex": "^1.19.0",
    "werift": "^0.22.9"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xmanatee/pub.git",
    "directory": "cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
