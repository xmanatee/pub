{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": ["tw-animate-css", "tailwindcss"],
  "workspaces": {
    ".": {
      "entry": ["convex/**/*.ts", "!convex/**/*.test.ts", "!convex/_generated/**"],
      "project": ["convex/**/*.ts", "shared/**/*.ts", "!convex/_generated/**"]
    },
    "web": {
      "entry": ["src/routes/**/*.tsx"],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.ts"],
      "paths": {
        "~/*": ["./src/*"],
        "@backend/*": ["../convex/*"],
        "@shared/*": ["../shared/*"]
      }
    },
    "cli": {
      "entry": ["src/index.ts", "src/app/live-daemon-entry.ts"],
      "project": ["src/**/*.ts"]
    },
    "relay": {
      "project": ["src/**/*.ts"],
      "paths": {
        "@shared/*": ["../shared/*"]
      }
    }
  }
}
