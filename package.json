{
  "name": "pub",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "convex dev --once && concurrently -r pnpm:dev:web pnpm:dev:db",
    "dev:web": "vite dev",
    "dev:db": "convex dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "deploy:convex": "convex deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check . && tsc --noEmit",
    "lint:fix": "biome check --fix .",
    "format": "biome format --fix .",
    "check": "biome check . && tsc --noEmit && vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.90",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/react-query": "0.0.0-alpha.8",
    "@convex-dev/sharded-counter": "^0.2.0",
    "@icons-pack/react-simple-icons": "^13.11.2",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@sentry/react": "^10.39.0",
    "@sentry/vite-plugin": "^4.9.1",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.161.3",
    "@tanstack/router-plugin": "^1.162.4",
    "@telegram-apps/sdk-react": "^3.3.9",
    "@tma.js/init-data-node": "^2.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "convex": "^1.19.0",
    "dompurify": "^3.3.1",
    "feed": "^5.2.0",
    "lucide-react": "^0.469.0",
    "marked": "^15.0.0",
    "nanoid": "^5.0.9",
    "posthog-js": "^1.352.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.12.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "node-datachannel",
      "protobufjs"
    ]
  }
