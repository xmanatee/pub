#!/usr/bin/env bash
set -euo pipefail

if (($# > 0)); then
  prompt="${!#}"
  codex_args=("${@:1:$#-1}")
else
  prompt=""
  codex_args=()
fi
workspace="${PUB_PROJECT_ROOT:-$PWD}"

if [[ -z "${PUB_AGENT_SOCKET:-}" && -n "${PUB_DAEMON_SOCKET:-}" ]]; then
  export PUB_AGENT_SOCKET="$PUB_DAEMON_SOCKET"
fi

# This script is launched by the Pub daemon. Child `pub` CLI calls must behave
# like client commands, not recursively enter daemon mode.
unset PUB_DAEMON_MODE
unset PUB_DAEMON_LAUNCHER_MODE
unset PUB_DAEMON_BRIDGE_SETTINGS
unset PUB_DAEMON_TUNNEL_CONFIG
unset PUB_DAEMON_API_BASE_URL
unset PUB_DAEMON_API_KEY
unset PUB_DAEMON_SOCKET
unset PUB_DAEMON_INFO
unset PUB_DAEMON_LOG
unset PUB_DAEMON_AGENT_NAME
export PUB_SKIP_UPDATE_CHECK=1

if [[ "$prompt" == *"[pub preflight] Connectivity probe."* ]]; then
  command -v codex >/dev/null
  command -v pub >/dev/null
  pub write "pong" >/dev/null
  exit 0
fi

tmpdir="${TMPDIR:-/tmp}"
tmpdir="${tmpdir%/}"
last_message="$(mktemp "$tmpdir/pub-codex-bridge.XXXXXX")"
codex_log="$(mktemp "$tmpdir/pub-codex-bridge.log.XXXXXX")"
trap 'rm -f "$last_message" "$codex_log"' EXIT

state_root="${PUB_CODEX_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/pub/codex-bridge}"
mkdir -p "$state_root"
live_label="$(printf '%s\n' "$prompt" | sed -n 's/.*\[Live: \([^]]*\)\].*/\1/p' | head -n 1)"
if [[ -z "$live_label" ]]; then
  live_label="workspace"
fi
session_key="$(printf '%s\n%s' "$workspace" "$live_label" | shasum -a 256 | awk '{print $1}')"
session_file="$state_root/$session_key.session"

if [[ "$prompt" == *"Session started."* ]]; then
  rm -f "$session_file"
fi

run_new_session() {
  codex exec \
    ${codex_args[@]+"${codex_args[@]}"} \
    --json \
    --ignore-user-config \
    --cd "$workspace" \
    --skip-git-repo-check \
    --dangerously-bypass-approvals-and-sandbox \
    --output-last-message "$last_message" \
    "$prompt" >"$codex_log" 2>&1 </dev/null

  awk -F'"' '/"type":"thread.started"/ { print $8; exit }' "$codex_log" >"$session_file"
}

run_resumed_session() {
  local session_id
  session_id="$(cat "$session_file")"
  (
    cd "$workspace"
    codex exec \
      ${codex_args[@]+"${codex_args[@]}"} \
      --json \
      --ignore-user-config \
      --skip-git-repo-check \
      --dangerously-bypass-approvals-and-sandbox \
      --output-last-message "$last_message" \
      resume \
      "$session_id" \
      "$prompt"
  ) >"$codex_log" 2>&1 </dev/null
}

if [[ -s "$session_file" ]]; then
  if ! run_resumed_session; then
    {
      echo "Codex resume failed; starting a fresh Pub bridge session."
      tail -n 40 "$codex_log"
    } >&2
    rm -f "$session_file"
    : >"$codex_log"
    run_new_session
  fi
else
  run_new_session
fi

cat "$last_message"
