{
  "buildCommand": "npx convex codegen && npx convex deploy -y --cmd 'pnpm --filter pub-web build'",
  "installCommand": "pnpm install",
  "framework": null,
  "outputDirectory": "web/dist",
  "rewrites": [
    {
      "source": "/__canvas__/:path(.*)",
      "has": [{ "type": "host", "value": "sandbox.pub.blue" }],
      "destination": "/sandbox/index.html"
    },
    {
      "source": "/sw.js",
      "has": [{ "type": "host", "value": "sandbox.pub.blue" }],
      "destination": "/sandbox/sw.js"
    },
    {
      "source": "/ph/static/:path(.*)",
      "destination": "https://eu-assets.i.posthog.com/static/:path"
    },
    { "source": "/ph/:path(.*)", "destination": "https://eu.i.posthog.com/:path" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "has": [{ "type": "host", "value": "sandbox.pub.blue" }],
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Content-Type", "value": "application/javascript" }
      ]
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "sandbox.pub.blue" }],
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors https://pub.blue" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/(.*)",
      "missing": [{ "type": "host", "value": "sandbox.pub.blue" }],
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
