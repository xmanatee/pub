{
  "name": "pub-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "pnpm test:live-core && pnpm test:live-ui && pnpm test:pub-models && pnpm test:pub-hook && pnpm test:pubs && pnpm test:app-lib && pnpm test:app-routes",
    "test:live-core": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/features/live src/features/preview-capture",
    "test:live-ui": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/components src/features/app-shell src/features/landing src/features/live-chat src/features/live-control-bar src/features/settings",
    "test:pub-models": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/features/pub/model",
    "test:pub-hook": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/features/pub/hooks/use-pub-live-model.test.tsx",
    "test:pubs": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/features/pubs",
    "test:app-lib": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/hooks src/lib",
    "test:app-routes": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/routes src/router.test.tsx",
    "test:watch": "NODE_OPTIONS=--max-old-space-size=8192 vitest",
    "test:e2e": "env -u NO_COLOR playwright test",
    "lint": "tsc --noEmit && bash ../scripts/no-raw-anchor.sh src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.90",
    "@convex-dev/react-query": "0.0.0-alpha.8",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@sentry/react": "^10.56.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.11",
    "@tanstack/router-plugin": "^1.168.14",
    "@telegram-apps/sdk-react": "^3.3.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.40.0",
    "eruda": "^3.4.3",
    "lucide-react": "^0.469.0",
    "posthog-js": "^1.380.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^2.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.12.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.8"
  }
}
